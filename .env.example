# Local development
PORT=3456
TODO_DB=./data/todo.json

# Durable cloud storage for Vercel. Prefer Neon Postgres.
# The app stores one normalized JSON document in app_store under TODO_POSTGRES_KEY.
DATABASE_URL=
TODO_POSTGRES_KEY=todo:store

# Legacy fallback: Vercel KV / Upstash Redis REST storage. Used only if DATABASE_URL is unset.
KV_REST_API_URL=
KV_REST_API_TOKEN=
TODO_KV_KEY=todo:store

# Household web-app auth (set these in Vercel before sharing the app URL)
HOUSEHOLD_PIN=<4-digit-pin>
AUTH_SECRET=

# Optional integration tokens. Use long random strings.
# x-todo-token or ?token= can authenticate API clients such as Hermes/Discord bridges.
HOUSEHOLD_API_TOKEN=
# x-eink-token or ?token= can authenticate e-paper dashboard clients.
EINK_API_TOKEN=

# Alexa remains separately protected by its own token.
ALEXA_API_TOKEN=

# Optional e-paper/dashboard calendar integration.
# For one feed, set GOOGLE_CALENDAR_ICAL_URL to a private/secret iCal URL.
# For multiple feeds, prefer GOOGLE_CALENDAR_ICAL_URLS as JSON with id/label/color/url objects.
# Example: [{"id":"primary","label":"Justin","color":"#f6c944","url":"https://calendar.google.com/.../basic.ics"}]
GOOGLE_CALENDAR_ICAL_URL=
GOOGLE_CALENDAR_ICAL_URLS=
FAMILY_CALENDAR_ID=family12925651382350424080@group.calendar.google.com
GOOGLE_API_SCRIPT=
EINK_CALENDAR_ENABLED=true
EINK_CALENDAR_DAYS=14
EINK_CALENDAR_MAX=8
EINK_FACTS_ENABLED=true
EINK_FACT_CACHE_MS=3600000
